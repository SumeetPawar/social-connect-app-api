APP_NAME=Fitness Steps API
ENV=dev

# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fitness_steps
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/fitnessdb

JWT_SECRET=change_me_to_long_random_string
JWT_ALG=HS256
ACCESS_TOKEN_MIN=43200
REFRESH_TOKEN_DAYS=365

AI_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-04-01-preview